# M87 Governed Swarm - Environment Configuration
# Copy this to .env and customize for your deployment

# ---- P0.A: Scoped API Keys ----
# Bootstrap key (admin-only). CHANGE THIS to a long random secret.
M87_BOOTSTRAP_KEY=change-this-to-a-long-random-secret

# Legacy key (backward compat — new deployments should use scoped keys below)
M87_API_KEY=change-this-to-a-long-random-secret

# Per-service scoped keys (generated once, seeded at startup)
# Each service gets only the endpoints/effects it needs.
# Leave empty to skip seeding (service falls back to M87_API_KEY).
M87_RUNNER_KEY=
M87_CASEY_KEY=
M87_JORDAN_KEY=
M87_RILEY_KEY=
M87_NOTIFIER_KEY=

# ---- Environment ----
# dev | staging | prod — affects kill-switch lockdown and security defaults
M87_ENV=dev

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Postgres ----
POSTGRES_PASSWORD=m87-dev-password

# ---- Notifications ----
# Webhook URL for notifications (Slack, Discord, etc.)
# Leave empty to disable webhook notifications
WEBHOOK_URL=

# ---- Test/Debug ----
# Enable test endpoints (/v1/admin/emit) - ONLY for running proof tests
M87_ENABLE_TEST_ENDPOINTS=false

# ---- P1.B: Kill-switch ----
# Emergency-only: bypass Phase 3-6 governance (requires authorization in prod)
# M87_DISABLE_PHASE36_GOVERNANCE=0
# M87_KILLSWITCH_OVERRIDE_PATH=

# ---- P2.A: Rate Limiting ----
# Max proposals per minute per principal (default: 30)
# M87_RATE_LIMIT_PROPOSALS_PER_MIN=30

# ---- Runner ----
M87_MAX_RUNNER_RESULT_BYTES=65536
# Challenge secret for Phase 3-6 adversarial review
M87_CHALLENGE_SECRET=change-me-in-production
